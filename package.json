{
  "name": "tree-sitter-sas",
  "version": "0.3.3",
  "description": "SAS language grammar for tree-sitter",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ix-infrastructure/tree-sitter-sas.git"
  },
  "funding": "",
  "license": "MIT",
  "author": {
    "name": "Brandon Garate",
    "email": "bgarate@ix-infra.com",
    "url": "ix-infra.com"
  },
  "main": "bindings/node/index.js",
  "types": "bindings/node/index.d.ts",
  "exports": {
    ".": "./bindings/node/index.js"
  },
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "sas"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**",
    "*.wasm"
  ],
  "dependencies": {
    "node-addon-api": "^8.5.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "prebuildify": "^6.0.1",
    "tree-sitter": "^0.25.0",
    "tree-sitter-cli": "~0.24.7"
  },
  "peerDependencies": {
    "tree-sitter": ">=0.21.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "scripts": {
    "install": "node-gyp-build",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "node --test bindings/node/*_test.js"
  }
}
