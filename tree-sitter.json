{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "tree_sitter_sas",
      "camelcase": "TreeSitterSas",
      "title": "SAS",
      "scope": "source.sas",
      "file-types": [
        "sas"
      ],
      "injection-regex": "^tree_sitter_sas$",
      "class-name": "TreeSitterTreeSitterSas"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "SAS language grammar for tree-sitter",
    "authors": [
      {
        "name": "Brandon Garate",
        "email": "bgarate@ix-infra.com",
        "url": "ix-infra.com"
      }
    ],
    "links": {
      "repository": "https://github.com/ix-infrastructure/tree-sitter-sas",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}